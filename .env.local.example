# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# WhatsApp — your business WhatsApp number in international format (no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=265993000000

# Admin email — used for Supabase auth admin account
NEXT_PUBLIC_ADMIN_EMAIL=admin@watchgalore265.com
